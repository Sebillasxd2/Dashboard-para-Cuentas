rules_version = '2';
// Reglas de seguridad de Firestore para el Dashboard de Cuentas.
// Cada usuario solo puede leer/escribir SU propio documento (su uid).
// Cópialas en: Consola de Firebase > Firestore Database > Reglas > Publicar.
service cloud.firestore {
  match /databases/{database}/documents {
    match /dashboards/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
